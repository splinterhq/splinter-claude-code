#!/bin/bash
# scripts/spl-signal
# Usage: spl-signal <event_name> [optional_context]
# Events: task_start task_advance task_finish file_read file_write tool_use error checkpoint

STORE="splinter_artifact"
SPLINTER_PREFIX=${SPLINTER_PREFIX}

# If you want the lights to blink in a more distributed, 
# less-sequential way, assign tasks to different quadrants
# of the matrix (e.g. a couple near lcars_60+ and some near
# lcars_30+, etc.. )

declare -A EVENT_KEYS=(
    [task_start]="lcars_2"
    [task_advance]="lcars_1"
    [task_finish]="lcars_3"
    [file_read]="lcars_4"
    [file_write]="lcars_5"
    [tool_use]="lcars_6"
    [error]="lcars_7"
    [checkpoint]="lcars_8"
)

EVENT="${1}"
KEY="${EVENT_KEYS[$EVENT]}"

if [ -z "$KEY" ]; then
    echo "spl-signal: unknown event '$EVENT'" >&2
    exit 1
fi

if [ -z "$SPLINTER_PREFIX" ]; then
	splinterctl --use "$STORE" bump "$KEY"
else
	splinterctl --use "$STORE" --prefix "$SPLINTER_PREFIX" bump "$KEY"
fi

